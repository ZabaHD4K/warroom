# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Scraper intervals
SCRAPER_ACLED_INTERVAL_HOURS=6
SCRAPER_GDELT_INTERVAL_MINUTES=15
SCRAPER_RSS_INTERVAL_HOURS=1
